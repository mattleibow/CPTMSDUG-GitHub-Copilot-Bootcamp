@page "/monkeys"
@attribute [StreamRendering]
@using BootcampWebApp.Models
@using BootcampWebApp.Services
@inject MonkeyService MonkeyService

<PageTitle>Monkeys</PageTitle>

<h1>🐵 Amazing Monkeys</h1>

<p>Discover the fascinating world of monkeys from around the globe!</p>

@if (monkeys == null)
{
    <div class="text-center">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2"><em>Loading amazing monkeys...</em></p>
    </div>
}
else if (monkeys.Length == 0)
{
    <div class="alert alert-warning" role="alert">
        <h4 class="alert-heading">No monkeys found!</h4>
        <p>We couldn't load the monkey data. Please try again later.</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var monkey in monkeys)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm">
                    <img src="@monkey.Image" class="card-img-top" alt="@monkey.Name" style="height: 200px; object-fit: cover;" />
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@monkey.Name</h5>
                        <p class="text-muted mb-2">
                            <i class="bi bi-geo-alt"></i> @monkey.Location
                        </p>
                        <p class="card-text flex-grow-1">@monkey.Details</p>
                        <div class="mt-auto">
                            <small class="text-muted">
                                <i class="bi bi-people"></i> Population: @monkey.Population.ToString("N0")
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private Monkey[]? monkeys;

    protected override async Task OnInitializedAsync()
    {
        // Simulate asynchronous loading to demonstrate streaming rendering
        await Task.Delay(500);
        
        monkeys = await MonkeyService.GetMonkeysAsync();
    }
}