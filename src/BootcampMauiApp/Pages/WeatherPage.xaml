<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BootcampMauiApp.Pages.WeatherPage"
             Title="Weather">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            
            <Label
                Text="Weather"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="This component demonstrates showing data."
                Style="{StaticResource SubHeadline}" />

            <Label
                x:Name="LoadingLabel"
                Text="Loading..."
                IsVisible="True" />

            <CollectionView
                x:Name="WeatherCollectionView"
                IsVisible="False">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="10" RowDefinitions="Auto,Auto">
                            <StackLayout Grid.Row="0" Orientation="Horizontal" Spacing="10">
                                <Label Text="{Binding Date, StringFormat='{0:d}'}" FontAttributes="Bold" />
                                <Label Text="{Binding TemperatureC, StringFormat='{0}°C'}" />
                                <Label Text="{Binding TemperatureF, StringFormat='{0}°F'}" />
                                <Label Text="{Binding Summary}" />
                            </StackLayout>
                            <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="LightGray" Margin="0,5,0,0" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>